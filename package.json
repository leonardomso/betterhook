{
  "name": "betterhook-monorepo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "bench": "turbo run bench",
    "docs:dev": "turbo run dev --filter=@betterhook/docs",
    "docs:check": "turbo run check --filter=@betterhook/docs",
    "fmt": "cargo fmt --all",
    "fmt:check": "cargo fmt --all -- --check"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "engines": {
    "node": ">=20"
  }
}
