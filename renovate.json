{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    "group:allNonMajor",
    ":enableVulnerabilityAlerts",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "cargo": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group all Rust dependency updates into one PR",
      "matchManagers": ["cargo"],
      "groupName": "rust dependencies",
      "commitMessageTopic": "rust dependencies",
      "schedule": ["before 9am on monday"]
    },
    {
      "description": "Group all GitHub Actions updates into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "commitMessageTopic": "github actions",
      "schedule": ["before 9am on monday"]
    },
    {
      "description": "Auto-merge minor and patch Rust updates",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Auto-merge GitHub Actions patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Weekly Cargo.lock refresh",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "enabled": true,
      "schedule": ["before 9am on monday"]
    }
  ]
}
